YARNINSIGHT_DB_PATH=./yarn_insight.db
YARNINSIGHT_CSV_PATH=./data/yarn_data.csv
YARNINSIGHT_PASSWORD_ITERATIONS=260000
YARNINSIGHT_SQLITE_JOURNAL_MODE=WAL

# Required for production database initialization.
YARNINSIGHT_ADMIN_EMAIL=admin@your-company.com
YARNINSIGHT_ADMIN_NAME=Admin User
YARNINSIGHT_ADMIN_PASSWORD=replace-with-a-long-random-password

# Keep false in production. Set true only for local demo databases.
YARNINSIGHT_ALLOW_DEMO_USERS=false

# JWT auth (new for the FastAPI backend)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_MINUTES=480

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173
